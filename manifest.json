{
  "manifest_version": 3,
  "name": "Zara.ai - Futuristic AI Assistant",
  "version": "1.0.0",
  "description": "Voice‑enabled AI assistant with memory, tools, and Google UK voice.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://openrouter.ai/*",
    "https://api.open-meteo.com/*",
    "https://geocoding-api.open-meteo.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
