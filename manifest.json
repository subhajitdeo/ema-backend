{
  "manifest_version": 3,
  "name": "Zara",
  "version": "1.0.0",
  "description": "Your voice‑activated assistant for local commands and app launcher.",
  "permissions": [
    "storage",
    "tabs",
    "commands"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Zara – Ctrl+Shift+Z"
  },
  "commands": {
    "activate-zara": {
      "suggested_key": {
        "default": "Ctrl+Shift+Z",
        "mac": "Command+Shift+Z"
      },
      "description": "Open Zara assistant"
    }
  }
}
