{
  "manifest_version": 3,
  "name": "Zara",
  "version": "1.0.0",
  "description": "Your intelligent voice & text assistant with local commands and AI (OpenRouter).",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "commands"
  ],
  "host_permissions": [
    "https://openrouter.ai/api/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Zara – Ctrl+Shift+Z"
  },
  "commands": {
    "activate-zara": {
      "suggested_key": {
        "default": "Ctrl+Shift+Z",
        "mac": "Command+Shift+Z"
      },
      "description": "Open Zara assistant"
    }
  },
  "icons": {
    "128": "icon.png"
  }
}
